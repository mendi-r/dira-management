# Supabase — copy this file to .env and fill in your values
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Server-only key — NO VITE_ prefix so Vite never bundles this into frontend
# Set this in Vercel Dashboard → Settings → Environment Variables (Production only)
SUPABASE_SERVICE_ROLE=your-service-role-key-here
ALLOWED_ORIGIN=https://your-domain.vercel.app
